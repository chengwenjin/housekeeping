page {
  background-color: #F0F2F5;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: #212121;
}

.container {
  padding: 28rpx;
}

.card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.07);
}

.btn-primary {
  background: linear-gradient(135deg, #FF6B35, #FFB347);
  color: #FFFFFF;
  border-radius: 9999rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 8rpx 40rpx rgba(255, 107, 53, 0.35);
}

.btn-outline {
  background: transparent;
  color: #FF6B35;
  border: 3rpx solid #FF6B35;
  border-radius: 9999rpx;
  padding: 18rpx 36rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.btn-teal {
  background: linear-gradient(135deg, #2EC4B6, #4DD9CC);
  color: #FFFFFF;
  border-radius: 9999rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
}

.btn-sm {
  padding: 12rpx 28rpx;
  font-size: 24rpx;
}

.chip {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 9999rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.chip-orange {
  background: #FFF0EB;
  color: #FF6B35;
}

.chip-teal {
  background: #E6FAF9;
  color: #2EC4B6;
}

.chip-green {
  background: #E8F5E9;
  color: #4CAF50;
}

.chip-yellow {
  background: #FFF8E1;
  color: #FF9800;
}

.status-open {
  background: #FFF0EB;
  color: #FF6B35;
}

.status-taken {
  background: #E8F5E9;
  color: #4CAF50;
}

.status-pending {
  background: #FFF8E1;
  color: #FF9800;
}

.divider {
  height: 1rpx;
  background: #F5F5F5;
  margin: 28rpx 0;
}

.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.text-ellipsis-2 {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.avatar {
  border-radius: 50%;
  overflow: hidden;
}

.price {
  color: #FF6B35;
  font-weight: 700;
}

.grad-header {
  background: linear-gradient(135deg, #FF6B35 0%, #FF9A3C 60%, #FFB347 100%);
}

.grad-primary {
  background: linear-gradient(135deg, #FF6B35, #FFB347);
}

.empty-text,
.loading-text,
.no-more-text {
  text-align: center;
  padding: 80rpx 40rpx;
  color: #9E9E9E;
  font-size: 24rpx;
}
