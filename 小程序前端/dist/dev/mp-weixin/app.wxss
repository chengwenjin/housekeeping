
/* 全局样式 */
:root {
  --primary: #FF6B35;
  --primary-light: #FF8C5A;
  --secondary: #2EC4B6;
  --grad-header: linear-gradient(135deg, #FF6B35 0%, #FF9A3C 60%, #FFB347 100%);
  --grad-primary: linear-gradient(135deg, #FF6B35, #FFB347);
  --grad-teal: linear-gradient(135deg, #2EC4B6, #4DD9CC);
  --gray-50: #FAFAFA;
  --gray-100: #F5F5F5;
  --gray-200: #EEEEEE;
  --gray-300: #E0E0E0;
  --gray-400: #BDBDBD;
  --gray-500: #9E9E9E;
  --gray-600: #757575;
  --gray-700: #616161;
  --gray-800: #424242;
  --gray-900: #212121;
  --success: #4CAF50;
  --warning: #FF9800;
  --error: #F44336;
  --info: #2196F3;
}
page {
  background-color: #F0F2F5;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: var(--gray-900);
}

/* 通用容器 */
.container {
  padding: 28rpx;
}

/* 卡片样式 */
.card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.07);
}

/* 按钮样式 */
.btn-primary {
  background: var(--grad-primary);
  color: #FFFFFF;
  border-radius: 9999rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 8rpx 40rpx rgba(255, 107, 53, 0.35);
}
.btn-outline {
  background: transparent;
  color: var(--primary);
  border: 3rpx solid var(--primary);
  border-radius: 9999rpx;
  padding: 18rpx 36rpx;
  font-size: 28rpx;
  font-weight: 600;
}
.btn-teal {
  background: var(--grad-teal);
  color: #FFFFFF;
  border-radius: 9999rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
}
.btn-sm {
  padding: 12rpx 28rpx;
  font-size: 24rpx;
}

/* 标签样式 */
.chip {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 9999rpx;
  font-size: 22rpx;
  font-weight: 500;
}
.chip-orange {
  background: #FFF0EB;
  color: var(--primary);
}
.chip-teal {
  background: #E6FAF9;
  color: var(--secondary);
}
.chip-green {
  background: #E8F5E9;
  color: var(--success);
}
.chip-yellow {
  background: #FFF8E1;
  color: var(--warning);
}

/* 状态标签 */
.status-open {
  background: #FFF0EB;
  color: var(--primary);
}
.status-taken {
  background: #E8F5E9;
  color: var(--success);
}
.status-pending {
  background: #FFF8E1;
  color: var(--warning);
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: var(--gray-100);
  margin: 28rpx 0;
}

/* 安全区域 */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* 文字截断 */
.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.text-ellipsis-2 {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 头像样式 */
.avatar {
  border-radius: 50%;
  overflow: hidden;
}

/* 价格样式 */
.price {
  color: var(--primary);
  font-weight: 700;
}

/* 渐变背景 */
.grad-header {
  background: var(--grad-header);
}
.grad-primary {
  background: var(--grad-primary);
}
