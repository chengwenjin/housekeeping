<view class="home-page">
  <view class="home-header">
    <view class="home-topbar">
      <view class="home-loc" bindtap="selectCity">
        <text class="loc-icon">📍</text>
        <text class="loc-text">{{currentCity}}</text>
        <text class="loc-arrow">▾</text>
      </view>
      <view class="home-avatar" bindtap="goToMine">
        <text wx:if="{{userInfo.avatarUrl}}">{{userInfo.avatarUrl}}</text>
        <text wx:else>😊</text>
      </view>
    </view>
    
    <view class="search-bar" bindtap="goToSearch">
      <text class="search-icon">🔍</text>
      <text class="search-placeholder">搜索家政服务需求...</text>
    </view>
  </view>
  
  <scroll-view class="home-cats" scroll-x>
    <view 
      wx:for="{{categories}}" 
      wx:key="id" 
      class="cat-item {{selectedCategory.id === item.id ? 'selected' : ''}}"
      bindtap="selectCategory"
      data-category="{{item}}"
    >
      <view class="cat-icon-wrap c{{(item.id % 5) + 1}}">
        <text>{{item.icon}}</text>
      </view>
      <text class="cat-text">{{item.name}}</text>
    </view>
  </scroll-view>
  
  <view class="banner" wx:if="{{homeData.banner}}">
    <view class="banner-text">
      <text class="banner-title">{{homeData.banner.title}}</text>
      <text class="banner-subtitle">{{homeData.banner.subtitle}}</text>
    </view>
    <view class="banner-btn" bindtap="goToDemands">去接单</view>
    <view class="banner-decor">🏠</view>
  </view>
  
  <view class="section-bar">
    <text class="section-title">附近需求 · {{selectedCategory.name || '全部'}}</text>
    <text class="section-filter" bindtap="showFilterModal">筛选 ▾</text>
  </view>
  
  <scroll-view 
    class="demand-list" 
    scroll-y
    bindscrolltolower="loadMore"
    refresher-enabled="{{true}}"
    refresher-triggered="{{refreshing}}"
    bindrefresherrefresh="onRefresh"
  >
    <view 
      wx:for="{{demandList}}" 
      wx:key="id" 
      class="demand-card"
      bindtap="goToDetail"
      data-id="{{item.id}}"
    >
      <view class="demand-card-top">
        <view class="demand-user">
          <view class="user-avatar ua{{(item.publisher.id % 4) + 1}}">
            <text>{{getAvatarEmoji(item.publisher.id)}}</text>
          </view>
          <view class="user-info">
            <text class="uname">{{item.publisher.nickname || '用户'}}</text>
            <text class="utime">{{item.createdAtText}} · {{item.location.district || ''}}</text>
          </view>
        </view>
        <view class="demand-status {{item.status === 1 ? 'ds-open' : 'ds-taken'}}">
          <text>{{item.statusText}}</text>
        </view>
      </view>
      
      <text class="demand-title">{{item.title}}</text>
      <text class="demand-desc">{{item.description}}</text>
      
      <view class="demand-meta">
        <view class="meta-item" wx:if="{{item.location.distance}}">
          <text>📍</text>
          <text>距您{{item.location.distance}}km</text>
        </view>
        <view class="meta-item" wx:if="{{item.serviceTimeDesc}}">
          <text>📅</text>
          <text>{{item.serviceTimeDesc}}</text>
        </view>
        <view class="meta-item" wx:if="{{item.minDuration}}">
          <text>⏱</text>
          <text>{{item.minDuration}}-{{item.maxDuration}}h</text>
        </view>
      </view>
      
      <view class="demand-footer">
        <view class="demand-price">
          <text class="price-num">¥{{item.expectedPrice}}</text>
          <text class="price-unit">/{{item.priceUnit || '小时'}}</text>
        </view>
        <button 
          wx:if="{{item.status === 1}}" 
          class="btn-take" 
          catchtap="takeOrder"
          data-demand="{{item}}"
        >
          立即接单
        </button>
        <button wx:else class="btn-take-sm" disabled>
          {{item.statusText}}
        </button>
      </view>
    </view>
    
    <view wx:if="{{loading}}" class="loading-text">
      <text>加载中...</text>
    </view>
    
    <view wx:if="{{!loading && demandList.length === 0}}" class="empty-text">
      <text>暂无需求数据</text>
    </view>
    
    <view wx:if="{{!loading && !hasMore && demandList.length > 0}}" class="no-more-text">
      <text>没有更多了</text>
    </view>
  </scroll-view>
</view>
