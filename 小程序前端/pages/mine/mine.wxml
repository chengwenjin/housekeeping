<view class="mine-page">
  <view class="mine-header">
    <view class="mine-user-row" wx:if="{{isLoggedIn}}">
      <view class="mine-avatar">
        <text wx:if="{{userInfo.avatarUrl}}">{{userInfo.avatarUrl}}</text>
        <text wx:else>😊</text>
      </view>
      <view class="mine-info">
        <text class="user-name">{{userInfo.nickname || '用户'}}</text>
        <text class="user-desc">{{userInfo.certificationStatus === 2 ? '已认证' : '未认证'}} {{userInfo.bio || ''}}</text>
      </view>
      <button class="mine-edit-btn" bindtap="goToEdit">
        <text>编辑</text>
      </button>
    </view>
    
    <view class="mine-user-row" wx:else bindtap="goToLogin">
      <view class="mine-avatar">
        <text>😊</text>
      </view>
      <view class="mine-info">
        <text class="user-name">点击登录</text>
        <text class="user-desc">登录后享受更多功能</text>
      </view>
    </view>
    
    <view class="mine-stats" wx:if="{{isLoggedIn}}">
      <view class="stat-item" bindtap="goToPublishedOrders">
        <text class="stat-num">{{userInfo.publishedCount || 0}}</text>
        <text class="stat-label">发布需求</text>
      </view>
      <view class="stat-item" bindtap="goToTakenOrders">
        <text class="stat-num">{{userInfo.takenCount || 0}}</text>
        <text class="stat-label">接单记录</text>
      </view>
      <view class="stat-item" bindtap="goToFollowing">
        <text class="stat-num">{{userInfo.followingCount || 0}}</text>
        <text class="stat-label">关注</text>
      </view>
      <view class="stat-item" bindtap="goToFootprints">
        <text class="stat-num">{{userInfo.followerCount || 0}}</text>
        <text class="stat-label">粉丝</text>
      </view>
    </view>
  </view>
  
  <view class="mine-body">
    <view class="mine-card" wx:if="{{isLoggedIn}}">
      <view class="mine-card-header">
        <text class="card-title">📋 我发布的需求</text>
        <text class="card-more" bindtap="goToPublishedOrders">查看全部</text>
      </view>
      <view 
        wx:for="{{publishedOrders}}" 
        wx:key="id" 
        class="order-item"
        bindtap="goToOrderDetail"
        data-id="{{item.id}}"
      >
        <view class="order-icon oi{{(item.demand.category.id % 3) + 1}}">
          <text>{{getCategoryIcon(item.demand.category.id)}}</text>
        </view>
        <view class="order-detail">
          <text class="order-title">{{item.demand.title || '需求'}}</text>
          <text class="order-sub">
            {{item.taker.nickname ? item.taker.nickname + ' 接单' : '尚未有人接单'}}
            {{item.serviceTime ? ' · ' + formatTime(item.serviceTime) : ''}}
          </text>
        </view>
        <view class="order-right">
          <text class="order-price">¥{{item.actualPrice || item.demand.expectedPrice || 0}}{{item.priceUnit ? '/' + item.priceUnit : ''}}</text>
          <view class="order-status {{getStatusClass(item.status)}}">
            <text>{{getStatusText(item.status)}}</text>
          </view>
        </view>
      </view>
      <view wx:if="{{publishedOrders.length === 0}}" class="empty-order">
        <text>暂无发布的需求</text>
      </view>
    </view>
    
    <view class="mine-card" wx:if="{{isLoggedIn}}">
      <view class="mine-card-header">
        <text class="card-title">🤝 我接的单</text>
        <text class="card-more" bindtap="goToTakenOrders">查看全部</text>
      </view>
      <view 
        wx:for="{{takenOrders}}" 
        wx:key="id" 
        class="order-item"
        bindtap="goToOrderDetail"
        data-id="{{item.id}}"
      >
        <view class="order-icon oi{{(item.demand.category.id % 3) + 1}}">
          <text>{{getCategoryIcon(item.demand.category.id)}}</text>
        </view>
        <view class="order-detail">
          <text class="order-title">{{item.demand.title || '需求'}}</text>
          <text class="order-sub">
            {{item.publisher.nickname ? item.publisher.nickname + ' 发布' : ''}}
            {{item.status === 4 ? ' · 已完成' : ''}}
          </text>
        </view>
        <view class="order-right">
          <text class="order-price">¥{{item.actualPrice || item.demand.expectedPrice || 0}}{{item.priceUnit ? '/' + item.priceUnit : ''}}</text>
          <view class="order-status {{getStatusClass(item.status)}}">
            <text>{{getStatusText(item.status)}}</text>
          </view>
        </view>
      </view>
      <view wx:if="{{takenOrders.length === 0}}" class="empty-order">
        <text>暂无接单记录</text>
      </view>
    </view>
    
    <view class="mine-card">
      <view class="menu-item" bindtap="goToFootprints">
        <view class="menu-icon-wrap mi1">
          <text>👣</text>
        </view>
        <text class="menu-label">我的足迹</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goToFollowing">
        <view class="menu-icon-wrap mi2">
          <text>❤️</text>
        </view>
        <text class="menu-label">我的关注</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goToReviews">
        <view class="menu-icon-wrap mi3">
          <text>⭐</text>
        </view>
        <text class="menu-label">我的评价</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goToMessages">
        <view class="menu-icon-wrap mi4">
          <text>🔔</text>
        </view>
        <text class="menu-label">消息通知</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goToSettings">
        <view class="menu-icon-wrap mi5">
          <text>⚙️</text>
        </view>
        <text class="menu-label">设置</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
    
    <view class="logout-btn" wx:if="{{isLoggedIn}}" bindtap="handleLogout">
      <text>退出登录</text>
    </view>
  </view>
</view>
